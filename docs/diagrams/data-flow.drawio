      <mxGeometry x="40" y="135" width="140" height="50" as="geometry"/>
    </mxCell>
    
    <!-- Arrow 1 -->
    <mxCell id="arrow1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;strokeWidth=2;endArrow=classic;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="180" y="105" as="sourcePoint"/>
        <mxPoint x="230" y="105" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    
    <!-- Step 2: Server Receive -->
    <mxCell id="step2" value="2. Server Receive" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="230" y="80" width="140" height="50" as="geometry"/>
