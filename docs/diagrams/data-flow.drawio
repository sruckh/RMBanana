    </mxCell>
    <mxCell id="download-detail" value="GET /api/download/:id&#xa;Browser downloads&#xa;Clean image file" style="text;html=1;strokeColor=#82b366;fillColor=#d5e8d4;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="610" y="285" width="140" height="50" as="geometry"/>
    </mxCell>
    
    <!-- Algorithm Box -->
    <mxCell id="algo-box" value="Watermark Algorithm" style="swimlane;horizontal=1;startSize=25;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="40" y="230" width="520" height="105" as="geometry"/>
    </mxCell>
    <mxCell id="algo-content" value="Google's Watermarking: watermarked = α × logo + (1 - α) × original&#xa;&#xa;RemoveBanana Reversal: original = (watermarked - α × logo) / (1 - α)&#xa;&#xa;✓ No AI guessing - pure mathematical reconstruction" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Courier New;fontSize=11;" vertex="1" parent="algo-box">
