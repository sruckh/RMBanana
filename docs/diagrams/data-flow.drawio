      <mxGeometry x="610" y="80" width="140" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="output-detail" value="Save to outputs/&#xa;Generate unique ID&#xa;Return download URL" style="text;html=1;strokeColor=#82b366;fillColor=#d5e8d4;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="610" y="135" width="140" height="50" as="geometry"/>
    </mxCell>
    
    <!-- Arrow 4 (down) -->
    <mxCell id="arrow4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;strokeWidth=2;endArrow=classic;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="680" y="185" as="sourcePoint"/>
