<mxGraphModel>
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    
    <!-- User Layer -->
    <mxCell id="user" value="User Browser" style="shape=actor;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;" vertex="1" parent="1">
      <mxGeometry x="340" y="40" width="60" height="60" as="geometry"/>
    </mxCell>
    
    <!-- Nginx Proxy Manager Container -->
    <mxCell id="npm-container" value="Nginx Proxy Manager&#xa;(Existing Infrastructure)" style="swimlane;horizontal=1;startSize=30;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="180" y="140" width="380" height="80" as="geometry"/>
    </mxCell>
    <mxCell id="npm" value="Reverse Proxy&#xa;Port 80/443" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="npm-container">
      <mxGeometry x="120" y="35" width="140" height="40" as="geometry"/>
    </mxCell>
    
    <!-- Docker Network Container -->
    <mxCell id="docker-net" value="shared_net (Docker Network)" style="swimlane;horizontal=1;startSize=30;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="80" y="260" width="560" height="300" as="geometry"/>
    </mxCell>
    
    <!-- RemoveBanana Container -->
    <mxCell id="app-container" value="removebanana Container (Port 3000)" style="swimlane;horizontal=1;startSize=30;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;" vertex="1" parent="docker-net">
      <mxGeometry x="40" y="50" width="480" height="230" as="geometry"/>
    </mxCell>
    
    <!-- Frontend -->
    <mxCell id="frontend" value="Frontend&#xa;(HTML/CSS/JS)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="app-container">
      <mxGeometry x="20" y="45" width="100" height="50" as="geometry"/>
    </mxCell>
    
    <!-- Express Server -->
    <mxCell id="express" value="Express.js&#xa;Server" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="app-container">
      <mxGeometry x="150" y="45" width="100" height="50" as="geometry"/>
    </mxCell>
    
    <!-- API Endpoints -->
    <mxCell id="api" value="API Endpoints&#xa;/api/remove-watermark&#xa;/api/download/:id&#xa;/api/health" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;spacingLeft=8;" vertex="1" parent="app-container">
      <mxGeometry x="280" y="40" width="170" height="60" as="geometry"/>
    </mxCell>
    
    <!-- RemoveBanana Library -->
    <mxCell id="lib" value="RemoveBanana&#xa;Library" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;" vertex="1" parent="app-container">
      <mxGeometry x="40" y="120" width="120" height="50" as="geometry"/>
    </mxCell>
    
    <!-- Canvas -->
    <mxCell id="canvas" value="Canvas&#xa;Image Processing" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="app-container">
      <mxGeometry x="180" y="120" width="120" height="50" as="geometry"/>
    </mxCell>
    
    <!-- Multer -->
    <mxCell id="multer" value="Multer&#xa;File Upload" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="app-container">
      <mxGeometry x="320" y="120" width="120" height="50" as="geometry"/>
    </mxCell>
    
    <!-- Storage -->
    <mxCell id="storage" value="uploads/&#xa;outputs/" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="app-container">
      <mxGeometry x="180" y="175" width="120" height="50" as="geometry"/>
    </mxCell>
    
    <!-- Arrows -->
    <mxCell id="arrow1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;strokeWidth=2;endArrow=classic;" edge="1" parent="1" source="user" target="npm">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    
    <mxCell id="arrow2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;strokeWidth=2;endArrow=classic;" edge="1" parent="1" source="npm" target="express">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    
    <!-- Internal connections -->
    <mxCell id="conn1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#6c8ebf;endArrow=classic;" edge="1" parent="app-container" source="frontend" target="express">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    
    <mxCell id="conn2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#6c8ebf;endArrow=classic;" edge="1" parent="app-container" source="express" target="api">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    
    <mxCell id="conn3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#d79b00;endArrow=classic;" edge="1" parent="app-container" source="api" target="lib">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    
  </root>
</mxGraphModel>